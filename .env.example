# Imprint / voice-forge public-safe environment example
# Copy to .env for local use. Never commit .env.

IMPRINT_CONFIG_FILE=./imprint.config.yaml
IMPRINT_DB_URL=sqlite:///./data/imprint.db
IMPRINT_OUTPUT_DIR=./exports
IMPRINT_REDACTION_MODE=strict
IMPRINT_LOG_LEVEL=INFO

# Optional OpenAI-compatible LLM endpoint
IMPRINT_LLM_PROVIDER=openai_compatible
IMPRINT_LLM_BASE_URL=http://localhost:8000/v1
IMPRINT_LLM_API_KEY=replace-with-local-key
IMPRINT_LLM_MODEL=local-model-name
IMPRINT_LLM_TIMEOUT_SECONDS=120

# Optional OpenAI-compatible embeddings endpoint
IMPRINT_EMBEDDINGS_PROVIDER=openai_compatible
IMPRINT_EMBEDDINGS_BASE_URL=http://localhost:8000/v1
IMPRINT_EMBEDDINGS_API_KEY=replace-with-local-key
IMPRINT_EMBEDDINGS_MODEL=local-embedding-model

# Optional local/private connector examples. Keep real values in .env only.
IMPRINT_SOURCE_SQL_ENABLED=false
IMPRINT_SOURCE_SQL_DSN=postgresql://user:pass@localhost:5432/database
IMPRINT_SOURCE_GMAIL_ENABLED=false
IMPRINT_SOURCE_GMAIL_CREDENTIALS_FILE=/path/to/local/credentials.json
