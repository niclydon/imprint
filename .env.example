# Imprint public-safe environment example
# Copy to .env for local use. Never commit .env.

IMPRINT_CONFIG_FILE=./imprint.config.yaml
IMPRINT_OUTPUT_DIR=./exports
IMPRINT_REDACTION_MODE=strict
IMPRINT_LOG_LEVEL=INFO

# Optional local-only model endpoint for future profile-affecting roles.
# Not required for default synthetic runs, connector dry-runs, or `imprint example`.
# IMPRINT_LLM_PROVIDER=openai_compatible
# IMPRINT_LLM_BASE_URL=http://localhost:8000/v1
# IMPRINT_LLM_API_KEY=
# IMPRINT_LLM_MODEL=local-model-name
# IMPRINT_LLM_TIMEOUT_SECONDS=120

# Optional local/private connector env var examples.
# Keep real values in .env only and reference them from ignored config.
# IMPRINT_PRIVATE_SOURCE_TOKEN=
# IMPRINT_PRIVATE_MANIFEST_ROOT=./private/sources
